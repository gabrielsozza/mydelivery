# ════════════════════════════════════════════════════════════════════════
# MyDelivery — variáveis de ambiente (TEMPLATE PÚBLICO)
# ════════════════════════════════════════════════════════════════════════
# ⚠️  ESTE ARQUIVO É COMMITADO NO GITHUB. NUNCA COLOQUE CREDENCIAIS REAIS AQUI.
# Copie pra .env (gitignored) ou configure direto no painel do Railway/host.

# ── Servidor ──
PORT=8080

# ── Banco de dados ──
DB_URL=jdbc:mysql://localhost:3306/mydelivery_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=America/Sao_Paulo&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=REPLACE_WITH_YOUR_MYSQL_PASSWORD

# ── JWT (gere com: openssl rand -base64 64) ──
JWT_SECRET=REPLACE_WITH_BASE64_RANDOM_64_BYTES
JWT_EXPIRATION=28800000
JWT_REFRESH_EXPIRATION=604800000

# ── Email (Gmail App Password: https://myaccount.google.com/apppasswords) ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=REPLACE_WITH_YOUR_EMAIL
MAIL_PASSWORD=REPLACE_WITH_APP_PASSWORD
MAIL_FROM=noreply@mydelivery.app
MAIL_FROM_NAME=MyDelivery

# ── URLs públicas ──
APP_URL=http://localhost:5500
API_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ── Cloudinary (https://cloudinary.com/console) ──
CLOUDINARY_CLOUD_NAME=REPLACE_WITH_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_API_SECRET

# ── Evolution API (WhatsApp) ──
EVOLUTION_BASE_URL=http://localhost:8081
EVOLUTION_API_KEY=REPLACE_WITH_EVOLUTION_API_KEY
EVOLUTION_WEBHOOK_BASE_URL=http://localhost:8080

# ── Mercado Pago ──
MP_WEBHOOK_URL=http://localhost:8080/api/webhooks/mercadopago
