# Evolution API — variáveis para rodar LOCAL via docker-compose.
# Em produção (Railway) NÃO use este arquivo — configure direto no painel.
# Veja README.md desta pasta para as variáveis de produção.

SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://localhost:8081

AUTHENTICATION_API_KEY=REPLACE_WITH_RANDOM_HEX_32_BYTES
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

DATABASE_ENABLED=false
CACHE_REDIS_ENABLED=false
CACHE_LOCAL_ENABLED=true

LANGUAGE=pt-BR
CONFIG_SESSION_PHONE_CLIENT=MyDelivery
CONFIG_SESSION_PHONE_NAME=Chrome
DEL_INSTANCE=false
QRCODE_LIMIT=30

WEBHOOK_GLOBAL_ENABLED=false
